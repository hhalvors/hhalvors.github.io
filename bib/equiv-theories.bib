              arguments in philosophy of physics.}
}

@article{dewar2019sophistication,
  author   = {Neil Dewar},
  title    = {Sophistication about Symmetries},
  journal  = {The British Journal for the Philosophy of Science},
  volume   = {70},
  number   = {2},
  pages    = {485--521},
  year     = {2019},
  doi      = {10.1093/bjps/axx021},
  keywords = {physics},
  annote   = {Defends a ``sophisticated'' attitude toward theories related
              by a symmetry (such as a gauge symmetry): rather than treating
              them as two distinct theories with the same empirical content,
              we should regard them as equivalent formulations of the same
              theory. Argues this avoids the problems of both naive realism
              about gauge structure and eliminativist reduction, drawing on
              the holonomy formulation of electromagnetism.}
}

@article{weatherall2024teleparallel,
  author   = {James Owen Weatherall and Insa Meskhidze},
  title    = {Are General Relativity and Teleparallel Gravity Theoretically Equivalent?},
  journal  = {Philosophy of Physics},
  volume   = {2},
  number   = {1},
  year     = {2024},
  doi      = {10.31389/pop.152},
  url      = {https://arxiv.org/abs/2406.15932},
  philsci  = {https://philsci-archive.pitt.edu/24593/},
  keywords = {physics},
  annote   = {A careful philosophical analysis of whether general relativity
              and teleparallel gravity---a reformulation using torsion rather
              than curvature---are theoretically equivalent. Applies standard
